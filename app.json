{
  "expo": {
    "name": "Launcher",
    "slug": "launcher",
    "version": "0.1.6",
    "orientation": "portrait",
    "scheme": "launcher",
    "icon": "./assets/branding/app-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.bri.launcher"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon-foreground.png",
        "monochromeImage": "./assets/branding/app-icon-monochrome.png",
        "backgroundColor": "#0D1821"
      },
      "package": "dev.bri.launcher"
    }
  }
}
